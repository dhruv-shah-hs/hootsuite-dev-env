

# Jira MCP (Cursor). Fill in; do not commit if this file contains real secrets.
JIRA_INSTANCE_URL=
JIRA_USER_EMAIL=
JIRA_API_KEY=

# GitHub MCP (Cursor). Optional (used by .cursor/external_sources/mcp.json)
GITHUB_PERSONAL_ACCESS_TOKEN=
# For GitHub Enterprise, set your GHES/GHEC hostname (must include https://)
GITHUB_HOST=

# Absolute path to the product service clone (e.g. ../service-entitlement). Used by align-branch, resolve-service, and checkout tools.
# Git/HTTPS URL is not supported yet. The multi-root .code-workspace can set this in the *integrated terminal*; for `python3 .cursor/tools/resolve-service.py` from an external shell, set a real path here or rely on hootsuite-dev-env.code-workspace discovery.
CURSOR_SERVICE_REPO=

CURSOR_REQUIRE_TASK_REPOSITORY=0

# Skip Done-ticket confirmation in pick-task / save-task-context (optional)
CURSOR_SKIP_DEPLOYED_CONFIRM=1

# Allow branch alignment to fall back to the shell cwd when no service root is configured (avoid in hootsuite-dev-env)
# CURSOR_ALLOW_ALIGN_BRANCH_CWD=1

# Max issue comments to load in pick-task (0 = unlimited, fetch all pages)
JIRA_MAX_COMMENTS_PER_ISSUE=0


# Skip the optional "Run the local service?" prompt at the end of interactive pick-task (optional)
PICK_TASK_NO_RUN_SERVICE_PROMPT=
