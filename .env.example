

# Jira MCP (Cursor). Fill in; do not commit if this file contains real secrets.
JIRA_INSTANCE_URL=
JIRA_USER_EMAIL=
JIRA_API_KEY=

# GitHub MCP (Cursor). Optional (used by .cursor/external_sources/mcp.json)
GITHUB_PERSONAL_ACCESS_TOKEN=
# For GitHub Enterprise, set your GHES/GHEC hostname (must include https://)
GITHUB_HOST=

CURSOR_SERVICE_REPO=

CURSOR_REQUIRE_TASK_REPOSITORY=0

# Skip Done-ticket confirmation in pick-task / save-task-context (optional)
CURSOR_SKIP_DEPLOYED_CONFIRM=1

# Allow branch alignment to fall back to the shell cwd when no service root is configured (avoid in hootsuite-dev-env)
# CURSOR_ALLOW_ALIGN_BRANCH_CWD=1
